apiVersion: v1
kind: Secret
metadata:
  name: pk-portal-secrets
  namespace: pk-portal
type: Opaque
stringData:
  POSTGRES_USER: pk_portal
  POSTGRES_PASSWORD: CHANGE_ME_IN_PRODUCTION
  JWT_SECRET: CHANGE_ME_IN_PRODUCTION
  DATABASE_URL: postgresql://pk_portal:CHANGE_ME_IN_PRODUCTION@postgres:5432/pk_portal
